[Unit]
Description=Al Mobarmg Celery Worker Service
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/almobarmg
EnvironmentFile=/home/ubuntu/.env
ExecStart=/home/ubuntu/venv/bin/celery -A backend.workers worker --loglevel=info --concurrency=2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
